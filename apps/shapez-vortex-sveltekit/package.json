{
  "name": "shapez-vortex-sveltekit",
  "version": "0.14.0",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare:schemas": "node resources/scripts/prepare-schemas.js",
    "prepare:models": "models ./static/models",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check",
    "test": "vitest run",
