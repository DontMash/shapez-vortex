    "@shapez-vortex/shape": "workspace:*",
    "@sveltejs/adapter-vercel": "^5.7.2",
    "@tailwindcss/vite": "^4.1.7",
    "@threlte/core": "^8.0.4",
    "@threlte/extras": "^9.2.1",
    "bits-ui": "^1.7.0",
    "class-variance-authority": "^0.7.1",
    "embla-carousel": "^8.6.0",
    "formsnap": "^2.0.1",
    "pocketbase": "^0.26.8",
    "screenfull": "^6.0.2",
    "sveltekit-superforms": "^2.29.1",
    "three": "^0.176.0",
    "three-custom-shader-material": "^6.3.7",
    "ua-parser-js": "1.0.40",
