{
  "name": "shapez-visualizer",
  "version": "0.14.2",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DontMash/shapez-vortex.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "prepare:buildings": "bash resources/scripts/buildings-pipeline.sh",
    "prepare:shapes": "bash resources/scripts/shapes-pipeline.sh",
    "dev": "vite dev",
    "dev:db": "docker-compose -f ./resources/deployment/compose.yml up --build",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "svelte-kit sync && NODE_OPTIONS=--max-old-space-size=8192 svelte-check --tsconfig ./tsconfig.json",
    "lint": "NODE_OPTIONS=--max-old-space-size=8192 eslint src",
    "lint:fix": "NODE_OPTIONS=--max-old-space-size=8192 eslint src --fix",
    "format": "prettier --check src",
    "format:fix": "prettier --write src",
    "release": "changelogen --release --push"
  },
  "changelog": {
    "templates": {
      "commitMessage": "chore(release): v{{newVersion}} [skip-ci]"
    }
  },
  "dependencies": {
    "@fontsource-variable/outfit": "^5.2.5",
    "@tailwindcss/vite": "^4.3.1",
    "@threlte/core": "^8.5.16",
    "@threlte/extras": "^9.21.0",
    "bits-ui": "^2.18.1",
    "class-variance-authority": "^0.7.1",
    "embla-carousel": "^8.6.0",
    "formsnap": "^2.0.1",
    "pako": "^2.1.0",
    "pocketbase": "^0.27.0",
    "screenfull": "^6.0.2",
    "sveltekit-superforms": "^2.30.1",
    "three": "^0.176.0",
    "three-custom-shader-material": "^6.3.7",
    "ua-parser-js": "1.0.40",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^9.39.4",
    "@iconify-json/tabler": "^1.2.35",
    "@iconify/tailwind4": "^1.2.3",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.65.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^25.9.2",
    "@types/pako": "^2.0.3",
    "@types/three": "^0.176.0",
    "@types/ua-parser-js": "^0.7.39",
    "@vitest/coverage-v8": "^4.1.8",
    "changelogen": "^0.6.2",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
